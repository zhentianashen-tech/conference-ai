# ═══════════════════════════════════════════════════════════════════
# Conference AI Assistant v3 — Environment Configuration
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────
# ANALYSIS ENGINE — Kimi (Moonshot AI)  [REQUIRED]
# https://platform.moonshot.cn → API Keys
# ───────────────────────────────────────────────────────────────────

MOONSHOT_API_KEY=sk-your_moonshot_key_here

# Model to use. kimi-k2.5 is the recommended default.
# Other options: moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k
ANALYSIS_MODEL=kimi-k2.5

# Base URL — change this to use a different OpenAI-compatible provider.
# Kimi (default):    https://api.moonshot.cn/v1
# OpenRouter:        https://openrouter.ai/api/v1
ANALYSIS_BASE_URL=https://api.moonshot.cn/v1

# Per-call limits
AGENT_MAX_TOKENS=1024
AGENT_TEMPERATURE=0.3


# ───────────────────────────────────────────────────────────────────
# ASR BACKEND (choose one)
# ───────────────────────────────────────────────────────────────────

# Provider: glm-local | openai | qwen
# glm-local runs GLM-ASR-Nano locally on Apple Silicon — zero API cost, low latency.
ASR_PROVIDER=glm-local

# ── Option A: GLM-ASR Local (default, recommended) ──────────────────
# Runs mlx-community/GLM-ASR-Nano-2512-4bit locally via a Python server.
# Setup:
#   pip install mlx-audio fastapi uvicorn
#   python scripts/glm-asr-server.py       ← run this in a separate terminal

# Model to load (first run downloads ~300 MB)
GLM_ASR_MODEL=mlx-community/GLM-ASR-Nano-2512-4bit

# Port the Python server listens on
GLM_ASR_PORT=8765

# Timeout per chunk request in ms (increase for slow hardware)
GLM_ASR_TIMEOUT_MS=15000

# ── Option B: OpenAI Whisper (cloud fallback) ────────────────────────
# ASR_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key_here

# ── Option C: Alibaba Qwen-ASR (cloud, good for Chinese) ────────────
# ASR_PROVIDER=qwen
# DASHSCOPE_API_KEY=your_dashscope_key_here
# QWEN_ASR_MODEL=qwen3-asr-flash-realtime
# DASHSCOPE_REGION=cn   # cn or intl


# ───────────────────────────────────────────────────────────────────
# AUDIO INPUT
# ───────────────────────────────────────────────────────────────────

# Audio device index from `npm run devices`. Use :0 for default mic.
AUDIO_DEVICE=:0

# Chunk size in seconds (only relevant for OpenAI Whisper fallback)
CHUNK_DURATION=4


# ───────────────────────────────────────────────────────────────────
# CONTEXT WINDOW & COMPACTION
# ───────────────────────────────────────────────────────────────────

# Max estimated tokens in the context window before hard-capping
CONTEXT_MAX_TOKENS=6000

# Token count that triggers automatic compaction (~40% of oldest segments)
CONTEXT_COMPACT_THRESH=5000

# Target token count for each compacted summary block
CONTEXT_SUMMARY_TOKENS=600


# ───────────────────────────────────────────────────────────────────
# PROACTIVE ANALYSIS
# ───────────────────────────────────────────────────────────────────

# Seconds between proactive analysis cycles
PROACTIVE_INTERVAL_SEC=30

# Proactivity threshold: low | medium | high
# low    — only high-priority insights surfaced
# medium — high + medium priority (recommended)
# high   — all insights including low priority
PROACTIVE_LEVEL=medium

# Set to false to disable background proactive analysis entirely
PROACTIVE_ENABLED=true


# ───────────────────────────────────────────────────────────────────
# CONCEPT DETECTOR
# ───────────────────────────────────────────────────────────────────

# Minimum milliseconds between concept intro API calls (rate limiting)
CONCEPT_DELAY_MS=4000

# Max concepts queued at once (excess are dropped)
CONCEPT_QUEUE_MAX=20
