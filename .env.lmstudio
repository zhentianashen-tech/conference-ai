# LM Studio Configuration for Conference Assistant
# =================================================
#
# This configuration uses LM Studio's local API server
# with the Qwen3.5-4B-Claude-4.6-Opus-Reasoning-Distilled model
#
# Setup Instructions:
# 1. Open LM Studio
# 2. Load the model: Jackrong/Qwen3.5-4B-Claude-4.6-Opus-Reasoning-Distilled-GGUF
# 3. Start the server: Developer tab → Start Server (default: localhost:1234)
# 4. Copy this file: cp .env.lmstudio .env
# 5. Run: npm start

# ═══════════════════════════════════════════════════════════════════════════
# ASR (Speech Recognition) - Keep using local Whisper
# ═══════════════════════════════════════════════════════════════════════════

WHISPER_BACKEND=nodejs-whisper
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cpu
WHISPER_VAD=true

# ═══════════════════════════════════════════════════════════════════════════
# Agent (LLM) - LM Studio Local Server
# ═══════════════════════════════════════════════════════════════════════════

# LM Studio OpenAI-compatible API endpoint
AGENT_BASE_URL=http://localhost:1234/v1
AGENT_API_KEY=lm-studio  # Can be any non-empty string for LM Studio

# Model identifier - use the exact name shown in LM Studio
# or leave as 'local-model' for auto-detection
AGENT_MODEL=Qwen3.5-4B-Claude-4.6-Opus-Reasoning-Distilled

# Optional: Specify context length if different from default
# AGENT_MAX_TOKENS=4096

# ═══════════════════════════════════════════════════════════════════════════
# Optional: Gemini for Search Enhancement
# ═══════════════════════════════════════════════════════════════════════════

# Even with local LLM, you can enable Gemini for better search summaries
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ═══════════════════════════════════════════════════════════════════════════
# Web Search
# ═══════════════════════════════════════════════════════════════════════════

DDG_SEARCH_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# Proactive Assistant
# ═══════════════════════════════════════════════════════════════════════════

PROACTIVE_ENABLED=true
PROACTIVE_LEVEL=medium
PROACTIVE_INTERVAL=10
PROACTIVE_COOLDOWN=30

# ═══════════════════════════════════════════════════════════════════════════
# Audio Configuration
# ═══════════════════════════════════════════════════════════════════════════

AUDIO_DEVICE=:0
CHUNK_DURATION=4
MAX_CONTEXT_SEGMENTS=15
